# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# =============================================================================
# Node / pnpm
# =============================================================================
node_modules/
*.tsbuildinfo
.pnpm-store/

# =============================================================================
# MemPalace — third-party Python install + LIVE palace data. Never ship.
# =============================================================================
mempalace/.venv/
mempalace/.mempalace/

# =============================================================================
# iga_mcp is CORE and PUBLIC: it is the Iga MCP server (generic, env-driven,
# no PII) — the open-source layer. Only the personal layer is gitignored:
# the session id (.iga-session-id, above) and machine env (IGA_HOME etc).
# Build venv is transient only:
# =============================================================================
iga_mcp/.venv/
iga_mcp/**/__pycache__/

# =============================================================================
# Skills CLI (`npx skills`) install artifacts — externally-managed, NOT
# iga-assistant skills. Symlinked into agent dirs by the skills installer.
# =============================================================================
.agents/
.claude/skills/
skills-lock.json
skills/find-skills

# =============================================================================
# Claude Code local config — per-user permissions, hooks, MCP paths
# =============================================================================
.claude/settings.local.json

# =============================================================================
# Three-layer config model (see CLAUDE.md) — personal overrides never ship
# =============================================================================
CLAUDE.local.md
rules/*.local.md
skills/*/SKILL.local.md

# The installed-rules layer is user-personalized; OSS contributors install
# from community_rules/ via `/iga install <pack>`. We ship community_rules/,
# we do NOT ship rules/.
rules/
!rules/.gitkeep

# =============================================================================
# Personal data stores
# =============================================================================
finance.db
rize_data.db
*.db
finance_rules.yml
queries.sql
projects.sql
FINANCE.md

# Personal one-off scripts (generalize before shipping)
load_finance.py
load_ksef.py
load_rize.py

# =============================================================================
# Scratch / ephemeral
# =============================================================================
scratch/
*.original.md
*.bak

# =============================================================================
# Runtime / engine + widget state — personal, never track or ship
# (proactive ledger, engine state JSON, widget data files, habit logs)
# =============================================================================
state/

# =============================================================================
# Secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Eval harness — local outputs
# =============================================================================
evals/node_modules/
evals/.env
evals/results/
evals/.promptfoo/
evals/calibration/contested-cases.jsonl

# =============================================================================
# Session / runtime state
# =============================================================================
.iga-session-id

# =============================================================================
# skills/email/ — contains PII in test fixtures (user emails + real names).
# Audit + anonymize before un-ignoring.
# =============================================================================
skills/email/

# =============================================================================
# skills/trainer/ — entirely personal (body state, health info, schedule).
# Lives only in the user's local tree; not shipped.
# =============================================================================
skills/trainer/

# =============================================================================
# Personal / not-yet-generalized skills — never ship as-is.
#   artilio-pm   : names the user + Artilio business strategy.
#   nutrition    : personal health (allergies, weight).
#   health-coach : personal coach (OSS candidate — generalize to
#                  community_skills/ later, without personal content).
#   palace-guard : OSS-valuable mechanism, but vocab.json is a roster of the
#                  user's REAL contacts/companies mined from the live palace.
#                  Generalize to community_skills/ later WITHOUT vocab.json.
# =============================================================================
skills/artilio-pm/
skills/nutrition/
skills/health-coach/
skills/palace-guard/

# =============================================================================
# community_skills/email/dist/ — compiled build output. Ship source, not dist.
# =============================================================================
community_skills/email/dist/

# =============================================================================
# OS / editor
# =============================================================================
.DS_Store
.vscode/
.idea/
*.swp
*~
*.log

# ggshield local scan cache
.cache_ggshield

# Claude Code Agent-tool isolated worktrees (harness-managed, transient)
.claude/worktrees/

# Brainstorming design specs — may carry personal context; never track
docs/superpowers/specs/
