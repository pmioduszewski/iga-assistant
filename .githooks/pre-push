#!/usr/bin/env bash
G="$(git rev-parse --show-toplevel)/.githooks/iga-guard.sh"
EMPTY=4b825dc642cb6eb9a060e54bf8d69288fbee4904
st=0
while read -r lref lsha rref rsha; do
  [ "$lsha" = "0000000000000000000000000000000000000000" ] && continue
  if printf '%s' "$rsha" | grep -qE '^0+$'; then range="$EMPTY..$lsha"; else range="$rsha..$lsha"; fi
  "$G" range "$range" || st=1
done
exit $st
