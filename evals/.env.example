# Required: API key used by both the system-under-test and the judge.
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults match what the harness ships with).
# System-under-test runs Sonnet; judge runs Opus. Don't judge a model with itself.
IGA_SUT_MODEL=claude-sonnet-4-6
IGA_JUDGE_MODEL=claude-opus-4-7

# Optional: where the mock MCP server logs go.
MOCK_MCP_LOG=./results/mock-mcp.log
