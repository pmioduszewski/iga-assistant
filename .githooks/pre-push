#!/usr/bin/env bash
# Safety net: LLM-judge the commits being pushed (catches content authored before
# the hook existed, or on another machine). Per-ref; fail-closed via the guard.
G="$(git rev-parse --show-toplevel)/.githooks/iga-guard.sh"
EMPTY=4b825dc642cb6eb9a060e54bf8d69288fbee4904
st=0
while read -r lref lsha rref rsha; do
  [ "$lsha" = "0000000000000000000000000000000000000000" ] && continue
  if printf '%s' "$rsha" | grep -qE '^0+$' || ! git cat-file -e "$rsha" 2>/dev/null; then
    base="$EMPTY"
  else
    base="$rsha"
  fi
  "$G" range "${base}..${lsha}" || st=1
done
exit $st
