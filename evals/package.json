{
  "name": "iga-evals",
  "version": "0.1.0",
  "private": true,
  "description": "Eval harness for Iga — catches stale-fact regressions in MemPalace retrieval.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:judges": "vitest run test/judges.test.ts",
    "test:scenarios": "vitest run test/scenarios.test.ts",
    "test:tier1": "vitest run test/scenarios.test.ts",
    "test:tier2": "vitest run test/scenarios-tier2.test.ts",
    "test:all": "vitest run",
    "promptfoo": "promptfoo eval -c promptfooconfig.yaml",
    "mock-mcp": "tsx mocks/mcp-server.ts",
    "calibrate": "tsx src/calibrateInChat.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "dotenv": "^16.4.5",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^22.0.0",
    "promptfoo": "^0.90.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
